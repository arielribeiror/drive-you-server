generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  google
  apple
  magic_link
}

enum VehicleVerificationStatus {
  pending_review
  verified
  rejected
}

enum VehicleVerificationSource {
  licensing_pdf
}

enum VehicleMaintenanceItem {
  engine_oil
  tires
  suspension
  brake_fluid
  brake_disc
  brake_pads
  tire_pressure
}

enum VehicleUsageProfile {
  severe
  light
}

enum VehicleAccessRole {
  owner
  shared
}

enum VehicleShareInviteStatus {
  pending
  accepted
  expired
  revoked
}

enum VehicleTripDetectionSource {
  gps
  motion_activity
  mixed
}

enum AppNotificationType {
  maintenance_due
  preventive_maintenance
  oil_change_logged
  driving_tip
}

enum AppNotificationTone {
  info
  success
  warning
}

enum PushDevicePlatform {
  android
  ios
  web
}

enum PushDeliveryStatus {
  pending
  sent
  delivered
  failed
}

model User {
  id              String           @id @default(cuid())
  email           String?
  emailNormalized String?          @unique
  name            String?
  avatarUrl       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  identities      AuthIdentity[]
  magicLinkTokens MagicLinkToken[]
  refreshTokens   RefreshToken[]
  vehicles        Vehicle[]
  sentVehicleShareInvites     VehicleShareInvite[] @relation("VehicleShareInvitesSent")
  acceptedVehicleShareInvites VehicleShareInvite[] @relation("VehicleShareInvitesAccepted")
  vehicleAccesses             VehicleAccess[]
  maintenanceBaselines        VehicleMaintenanceBaseline[]
  vehicleTrips                VehicleTrip[]
  appNotifications            AppNotification[]
  pushDevices                 PushDevice[]
}

model AuthIdentity {
  id              String       @id @default(cuid())
  userId          String
  provider        AuthProvider
  providerSubject String
  email           String?
  emailNormalized String?
  emailVerified   Boolean      @default(false)
  isPrivateEmail  Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([emailNormalized])
  @@index([userId])
}

model MagicLinkToken {
  id              String    @id @default(cuid())
  userId          String?
  email           String
  emailNormalized String
  tokenHash       String    @unique
  codeHash        String?
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime  @default(now())
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([emailNormalized])
  @@index([emailNormalized, codeHash])
  @@index([expiresAt])
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  tokenHash         String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  userAgent         String?
  ipAddress         String?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Vehicle {
  id                  String                    @id @default(cuid())
  userId              String
  plate               String
  displayName         String?
  renavam             String?
  brandModel          String?
  manufactureYear     Int?
  modelYear           Int?
  ownerName           String?
  ownerDocumentMasked String?
  currentOdometerKm   Int?
  currentOdometerIsEstimated Boolean @default(false)
  verificationStatus  VehicleVerificationStatus @default(pending_review)
  verificationSource  VehicleVerificationSource @default(licensing_pdf)
  documentHash        String?
  documentFileName    String?
  documentMimeType    String?
  documentSizeBytes   Int?
  heroImageOriginalUrl String?
  heroImageUrl         String?
  heroImageMimeType    String?
  heroImageSizeBytes   Int?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  user                User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accesses            VehicleAccess[]
  shareInvites        VehicleShareInvite[]
  maintenanceBaselines VehicleMaintenanceBaseline[]
  trips               VehicleTrip[]
  appNotifications    AppNotification[]

  @@unique([userId, renavam])
  @@index([plate])
  @@index([renavam])
  @@index([userId])
}

model VehicleTrip {
  id              String                     @id @default(cuid())
  vehicleId       String
  driverUserId    String
  clientTripId    String
  startedAt       DateTime
  endedAt         DateTime
  durationSeconds Int
  distanceMeters  Int
  averageSpeedKmh Int?
  maxSpeedKmh     Int?
  startLatitude   Float
  startLongitude  Float
  endLatitude     Float
  endLongitude    Float
  routePolyline   String?
  routeSampleCount Int                      @default(0)
  detectionSource VehicleTripDetectionSource
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  driver          User                      @relation(fields: [driverUserId], references: [id], onDelete: Cascade)
  vehicle         Vehicle                   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([driverUserId, clientTripId])
  @@index([vehicleId, startedAt])
  @@index([driverUserId, startedAt])
}

model VehicleShareInvite {
  id               String    @id @default(cuid())
  vehicleId        String
  inviterUserId    String
  acceptedByUserId String?
  status           VehicleShareInviteStatus @default(pending)
  tokenHash        String    @unique
  expiresAt        DateTime
  acceptedAt       DateTime?
  createdAt        DateTime  @default(now())
  vehicle          Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  inviter          User      @relation("VehicleShareInvitesSent", fields: [inviterUserId], references: [id], onDelete: Cascade)
  acceptedBy       User?     @relation("VehicleShareInvitesAccepted", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  acceptedAccess   VehicleAccess?

  @@index([vehicleId])
  @@index([inviterUserId])
  @@index([acceptedByUserId])
  @@index([status])
  @@index([expiresAt])
}

model VehicleAccess {
  id        String            @id @default(cuid())
  userId    String
  vehicleId String
  role      VehicleAccessRole @default(shared)
  inviteId  String?           @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle   Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  invite    VehicleShareInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@unique([userId, vehicleId])
  @@index([vehicleId])
  @@index([userId])
  @@index([role])
}

model VehicleMaintenanceBaseline {
  id             String                 @id @default(cuid())
  userId         String
  vehicleId      String
  item           VehicleMaintenanceItem
  performedAt    DateTime
  odometerKm     Int
  usageProfile   VehicleUsageProfile?
  intervalKm     Int
  intervalMonths Int?
  intervalDays   Int?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle        Vehicle                @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, item])
  @@index([vehicleId])
  @@index([userId])
  @@index([item])
}

model AppNotification {
  id         String              @id @default(cuid())
  userId     String
  vehicleId  String?
  type       AppNotificationType
  tone       AppNotificationTone @default(info)
  payload    Json
  dedupeKey  String
  readAt     DateTime?
  pushedAt   DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle    Vehicle?            @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  deliveries PushDelivery[]

  @@unique([userId, dedupeKey])
  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([vehicleId])
  @@index([type])
}

model PushDevice {
  id               String             @id @default(cuid())
  userId           String
  expoPushToken    String             @unique
  platform         PushDevicePlatform
  locale           String?
  isActive         Boolean            @default(true)
  lastRegisteredAt DateTime           @default(now())
  disabledAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries       PushDelivery[]

  @@index([userId, isActive])
  @@index([expoPushToken])
}

model PushDelivery {
  id              String             @id @default(cuid())
  notificationId  String
  deviceId        String?
  expoPushToken   String
  status          PushDeliveryStatus @default(pending)
  ticketId        String?
  error           String?
  receiptCheckedAt DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  notification    AppNotification    @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  device          PushDevice?        @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@unique([notificationId, deviceId])
  @@index([notificationId])
  @@index([ticketId])
  @@index([status, createdAt])
}
