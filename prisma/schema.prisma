generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  google
  apple
  magic_link
}

enum VehicleVerificationSource {
  licensing_pdf
}

enum VehicleMaintenanceItem {
  engine_oil
  tires
  suspension
  brake_fluid
  brake_disc
  brake_pads
  tire_pressure
}

enum VehicleUsageProfile {
  severe
  light
}

enum VehicleAccessRole {
  owner
  shared
}

enum FipeVehicleType {
  cars
  motorcycles
  trucks
}

enum FipeLinkSource {
  automatic
  confirmed
  manual
}

enum VehicleShareInviteStatus {
  pending
  accepted
  expired
  revoked
}

enum VehicleTripDetectionSource {
  gps
  motion_activity
  mixed
}

enum VehicleMaintenanceEventSource {
  onboarding
  manual
  baseline_update
}

enum AppNotificationType {
  maintenance_due
  preventive_maintenance
  oil_change_logged
  driving_tip
}

enum NotificationPreferenceType {
  maintenance_due
  preventive_maintenance
  oil_change_logged
  driving_tip
  trip_confirmation
}

enum AppNotificationTone {
  info
  success
  warning
}

enum PushDevicePlatform {
  android
  ios
  web
}

enum PushDeliveryStatus {
  pending
  sent
  delivered
  failed
}

model User {
  id              String           @id @default(cuid())
  email           String?
  emailNormalized String?          @unique
  name            String?
  avatarUrl       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  identities      AuthIdentity[]
  magicLinkTokens MagicLinkToken[]
  refreshTokens   RefreshToken[]
  vehicles        Vehicle[]
  documentConfirmedVehicles  Vehicle[] @relation("VehicleDocumentConfirmations")
  sentVehicleShareInvites     VehicleShareInvite[] @relation("VehicleShareInvitesSent")
  acceptedVehicleShareInvites VehicleShareInvite[] @relation("VehicleShareInvitesAccepted")
  vehicleAccesses             VehicleAccess[]
  maintenanceBaselines        VehicleMaintenanceBaseline[]
  maintenanceEvents           VehicleMaintenanceEvent[]
  vehicleTrips                VehicleTrip[]
  appNotifications            AppNotification[]
  notificationPreferences     NotificationPreference[]
  pushDevices                 PushDevice[]
}

model AuthIdentity {
  id              String       @id @default(cuid())
  userId          String
  provider        AuthProvider
  providerSubject String
  email           String?
  emailNormalized String?
  emailVerified   Boolean      @default(false)
  isPrivateEmail  Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([emailNormalized])
  @@index([userId])
}

model MagicLinkToken {
  id              String    @id @default(cuid())
  userId          String?
  email           String
  emailNormalized String
  tokenHash       String    @unique
  codeHash        String?
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime  @default(now())
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([emailNormalized])
  @@index([emailNormalized, codeHash])
  @@index([expiresAt])
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  tokenHash         String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  userAgent         String?
  ipAddress         String?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Vehicle {
  id                  String                    @id @default(cuid())
  userId              String
  plate               String
  displayName         String?
  renavam             String?
  brandModel          String?
  manufactureYear     Int?
  modelYear           Int?
  ownerName           String?
  ownerDocumentMasked String?
  currentOdometerKm   Int?
  currentOdometerIsEstimated Boolean @default(false)
  verificationSource  VehicleVerificationSource @default(licensing_pdf)
  documentHash        String?
  documentFileName    String?
  documentMimeType    String?
  documentSizeBytes   Int?
  documentConfirmedAt DateTime?
  documentConfirmedByUserId String?
  heroImageOriginalUrl String?
  heroImageUrl         String?
  heroImageMimeType    String?
  heroImageSizeBytes   Int?
  fipeVehicleType      FipeVehicleType?
  fipeBrandCode        String?
  fipeModelCode        String?
  fipeYearId           String?
  fipeCode             String?
  fipeDisplayName      String?
  fipeLinkSource       FipeLinkSource?
  fipeLinkedAt         DateTime?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  user                User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentConfirmedByUser User?                 @relation("VehicleDocumentConfirmations", fields: [documentConfirmedByUserId], references: [id], onDelete: SetNull)
  accesses            VehicleAccess[]
  shareInvites        VehicleShareInvite[]
  maintenanceBaselines VehicleMaintenanceBaseline[]
  maintenanceEvents    VehicleMaintenanceEvent[]
  trips               VehicleTrip[]
  appNotifications    AppNotification[]
  fipePrices          VehicleFipePrice[]

  @@unique([userId, renavam])
  @@index([plate])
  @@index([renavam])
  @@index([userId])
  @@index([fipeCode])
}

model VehicleFipePrice {
  id             String   @id @default(cuid())
  vehicleId      String
  fipeCode       String
  yearId         String
  referenceCode  String
  referenceMonth String
  priceCents     Int
  fetchedAt      DateTime @default(now())
  createdAt      DateTime @default(now())
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, fipeCode, yearId, referenceCode])
  @@index([vehicleId, fetchedAt])
  @@index([fipeCode, yearId])
}

model VehicleTrip {
  id              String                     @id @default(cuid())
  vehicleId       String
  driverUserId    String
  clientTripId    String
  startedAt       DateTime
  endedAt         DateTime
  durationSeconds Int
  distanceMeters  Int
  averageSpeedKmh Int?
  maxSpeedKmh     Int?
  startLatitude   Float
  startLongitude  Float
  endLatitude     Float
  endLongitude    Float
  routePolyline   String?
  routeSampleCount Int                      @default(0)
  detectionSource VehicleTripDetectionSource
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  driver          User                      @relation(fields: [driverUserId], references: [id], onDelete: Cascade)
  vehicle         Vehicle                   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([driverUserId, clientTripId])
  @@index([vehicleId, startedAt])
  @@index([driverUserId, startedAt])
}

model VehicleShareInvite {
  id               String    @id @default(cuid())
  vehicleId        String
  inviterUserId    String
  acceptedByUserId String?
  status           VehicleShareInviteStatus @default(pending)
  tokenHash        String    @unique
  expiresAt        DateTime
  acceptedAt       DateTime?
  createdAt        DateTime  @default(now())
  vehicle          Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  inviter          User      @relation("VehicleShareInvitesSent", fields: [inviterUserId], references: [id], onDelete: Cascade)
  acceptedBy       User?     @relation("VehicleShareInvitesAccepted", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  acceptedAccess   VehicleAccess?

  @@index([vehicleId])
  @@index([inviterUserId])
  @@index([acceptedByUserId])
  @@index([status])
  @@index([expiresAt])
}

model VehicleAccess {
  id        String            @id @default(cuid())
  userId    String
  vehicleId String
  role      VehicleAccessRole @default(shared)
  inviteId  String?           @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle   Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  invite    VehicleShareInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@unique([userId, vehicleId])
  @@index([vehicleId])
  @@index([userId])
  @@index([role])
}

model VehicleMaintenanceBaseline {
  id             String                 @id @default(cuid())
  userId         String
  vehicleId      String
  item           VehicleMaintenanceItem
  performedAt    DateTime
  odometerKm     Int
  usageProfile   VehicleUsageProfile?
  intervalKm     Int
  intervalMonths Int?
  intervalDays   Int?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle        Vehicle                @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, item])
  @@index([vehicleId])
  @@index([userId])
  @@index([item])
}

model VehicleMaintenanceEvent {
  id          String                    @id @default(cuid())
  userId      String
  vehicleId   String
  item        VehicleMaintenanceItem
  source      VehicleMaintenanceEventSource @default(manual)
  performedAt DateTime
  odometerKm  Int
  costCents   Int?
  notes       String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle     Vehicle                   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, performedAt])
  @@index([userId, performedAt])
  @@index([item])
}

model AppNotification {
  id         String              @id @default(cuid())
  userId     String
  vehicleId  String?
  type       AppNotificationType
  tone       AppNotificationTone @default(info)
  payload    Json
  dedupeKey  String
  readAt     DateTime?
  pushedAt   DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle    Vehicle?            @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  deliveries PushDelivery[]

  @@unique([userId, dedupeKey])
  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([vehicleId])
  @@index([type])
}

model NotificationPreference {
  id              String                     @id @default(cuid())
  userId          String
  type            NotificationPreferenceType
  inAppEnabled    Boolean                    @default(true)
  pushEnabled     Boolean                    @default(true)
  quietHoursStart String?
  quietHoursEnd   String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@index([type])
}

model PushDevice {
  id               String             @id @default(cuid())
  userId           String
  expoPushToken    String             @unique
  platform         PushDevicePlatform
  locale           String?
  isActive         Boolean            @default(true)
  lastRegisteredAt DateTime           @default(now())
  disabledAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries       PushDelivery[]

  @@index([userId, isActive])
  @@index([expoPushToken])
}

model PushDelivery {
  id              String             @id @default(cuid())
  notificationId  String
  deviceId        String?
  expoPushToken   String
  status          PushDeliveryStatus @default(pending)
  ticketId        String?
  error           String?
  receiptCheckedAt DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  notification    AppNotification    @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  device          PushDevice?        @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@unique([notificationId, deviceId])
  @@index([notificationId])
  @@index([ticketId])
  @@index([status, createdAt])
}
