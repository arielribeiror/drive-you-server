NODE_ENV=development
PORT=3333
HOST=0.0.0.0
DATABASE_URL=postgresql://driveyou:driveyou@localhost:5432/drive_you?schema=public
JWT_SECRET=change-me-to-a-long-random-secret-with-at-least-32-chars
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
MAGIC_LINK_TTL_MINUTES=15
MAGIC_LINK_BASE_URL=driveyou://auth/magic-link
CORS_ORIGIN=*

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=Drive You <auth@driveyou.app>

# Google ID token audiences, comma-separated or per platform.
GOOGLE_CLIENT_IDS=
GOOGLE_WEB_CLIENT_ID=107975666485-j7q39g1ig6nba76itb94a9788rbjtlo3.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Apple identity token audiences, usually the iOS bundle id for native sign-in.
APPLE_CLIENT_IDS=
APPLE_BUNDLE_ID=com.driveyou.app
